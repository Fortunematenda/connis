# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=connis

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# MikroTik RouterOS API (port 8728) — legacy fallback only
# Per-company routers are now stored in the database
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=
MIKROTIK_PORT=8728

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# Encryption key for router passwords (must be 32 chars)
ENCRYPTION_KEY=change-this-to-32-char-secret!!

# RADIUS Database (defaults to same PostgreSQL server, database 'radius')
RADIUS_DB_HOST=localhost
RADIUS_DB_PORT=5432
RADIUS_DB_USER=postgres
RADIUS_DB_PASSWORD=your_password_here
RADIUS_DB_NAME=radius
